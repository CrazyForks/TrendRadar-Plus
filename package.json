{
  "name": "hotnews-e2e-tests",
  "version": "1.0.0",
  "description": "E2E tests for Hotnews News Viewer",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "test:prod": "BASE_URL=https://hot.uihash.com VIEWER_PATH=/viewer playwright test --grep @prod",
    "test:prod:headed": "BASE_URL=https://hot.uihash.com VIEWER_PATH=/viewer playwright test --grep @prod --headed",
    "prebuild:js": "rm -f hotnews/web/static/js/chunk-*.js hotnews/web/static/js/explore-embedded-rss-*.js hotnews/web/static/js/favorites-*.js hotnews/web/static/js/platform-reorder-*.js hotnews/web/static/js/rss-catalog-preview-parity-*.js hotnews/web/static/js/subscription-*.js hotnews/web/static/js/topic-tracker-*.js hotnews/web/static/js/summary-modal-*.js hotnews/web/static/js/comment-preview-*.js hotnews/web/static/js/todo-*.js hotnews/web/static/js/subscribe-sidebar-*.js hotnews/web/static/js/payment-*.js && rm -rf hotnews/web/static/js/mobile",
    "build:js": "esbuild hotnews/web/static/js/src/index.js --bundle --splitting --format=esm --outdir=hotnews/web/static/js --minify && esbuild hotnews/web/static/js/src/index-mobile.js --bundle --splitting --format=esm --outdir=hotnews/web/static/js/mobile --minify",
    "build:js:watch": "esbuild hotnews/web/static/js/src/index.js --bundle --splitting --format=esm --outdir=hotnews/web/static/js --watch",
    "dev:write": "vite --config vite.config.write.js",
    "build:write": "vite build --config vite.config.write.js",
    "preview:write": "vite preview --config vite.config.write.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "esbuild": "^0.20.2",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@tiptap/core": "^3.18.0",
    "@tiptap/extension-bubble-menu": "^3.18.0",
    "@tiptap/extension-code-block-lowlight": "^3.18.0",
    "@tiptap/extension-dropcursor": "^3.18.0",
    "@tiptap/extension-highlight": "^3.18.0",
    "@tiptap/extension-image": "^3.18.0",
    "@tiptap/extension-link": "^3.18.0",
    "@tiptap/extension-placeholder": "^3.18.0",
    "@tiptap/extension-table": "^3.18.0",
    "@tiptap/extension-table-cell": "^3.18.0",
    "@tiptap/extension-table-header": "^3.18.0",
    "@tiptap/extension-table-row": "^3.18.0",
    "@tiptap/extension-text-align": "^3.18.0",
    "@tiptap/extension-typography": "^3.18.0",
    "@tiptap/pm": "^3.18.0",
    "@tiptap/starter-kit": "^3.18.0",
    "@tiptap/suggestion": "^3.18.0",
    "cropperjs": "^1.6.1",
    "lowlight": "^3.3.0",
    "tippy.js": "^6.3.7"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
