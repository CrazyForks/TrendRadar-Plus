{
  "compilerOptions": {
    "checkJs": true,
    "strict": false,
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {}
  },
  "include": ["./**/*.js"],
  "exclude": ["../index.js", "../chunk-*.js", "../*.js"]
}
